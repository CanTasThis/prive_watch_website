{
  "functions": {
    "api/watches.js": {
      "maxDuration": 10,
      "includeFiles": "../watches.json"
    },
    "api/img.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
